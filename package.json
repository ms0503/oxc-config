        },
        "./lint": {
            "import": "./dist/lint/index.js",
            "types": "./dist/lint/index.d.ts"
        },
        "./utils": {
            "import": "./dist/utils/index.js",
            "types": "./dist/utils/index.d.ts"
        }
    },
    "name": "@ms0503/oxc-config",
