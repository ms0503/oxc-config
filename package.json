{
    "dependencies": {
        "eslint-plugin-perfectionist": "^5.8.0",
        "oxfmt": "^0.56.0",
        "oxlint": "^1.72.0",
        "oxlint-tsgolint": "^0.23.0"
    },
    "devDependencies": {
        "typescript": "catalog:"
    },
    "engines": {
        "node": ">=22.18.0"
    },
    "exports": {
        "./fmt": {
            "import": "./dist/fmt/index.js",
